{
    "$schema": "./@types/schema/package/index.json",
    "package_version": 2,
    "name": "cocos-mcp-server",
    "version": "2.11.1",
    "author": "shang (fork of LiDaxian's cocos-mcp-server v1.4.0)",
    "editor": ">=3.8.6",
    "scripts": {
        "preinstall": "node ./scripts/preinstall.js",
        "build": "tsc",
        "watch": "tsc -w",
        "smoke": "node scripts/smoke-mcp-sdk.js",
        "check:gemini": "node scripts/check-gemini-compat.js"
    },
    "description": "i18n:cocos-mcp-server.description",
    "main": "./dist/main.js",
    "releaseDate": "2026-05-03T03:13:28+08:00",
    "homepage": "https://github.com/arnie1128/cocos-mcp-server",
    "repository": {
        "type": "git",
        "url": "https://github.com/arnie1128/cocos-mcp-server.git"
    },
    "bugs": {
        "url": "https://github.com/arnie1128/cocos-mcp-server/issues"
    },
    "license": "MIT",
    "keywords": [
        "mcp",
        "model-context-protocol",
        "cocos-creator",
        "ai",
        "claude",
        "cursor",
        "scene",
        "node",
        "prefab",
        "editor-extension"
    ],
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "fs-extra": "^11.3.0",
        "uuid": "^9.0.1",
        "vue": "^3.1.4",
        "zod": "^4.4.1"
    },
    "devDependencies": {
        "@cocos/creator-types": "^3.8.6",
        "@types/fs-extra": "^9.0.5",
        "@types/node": "^18.17.1",
        "@types/uuid": "^9.0.8",
        "typescript": "^5.8.2"
    },
    "panels": {
        "default": {
            "title": "i18n:cocos-mcp-server.panel_title",
            "type": "dockable",
            "main": "dist/panels/default",
            "icon": "./static/icon.png",
            "size": {
                "min-width": 480,
                "min-height": 640,
                "width": 640,
                "height": 720
            }
        }
    },
    "contributions": {
        "menu": [
            {
                "path": "i18n:menu.extension/Cocos MCP Server",
                "label": "i18n:cocos-mcp-server.open_panel",
                "message": "open-panel"
            }
        ],
        "messages": {
            "open-panel": {
                "methods": [
                    "openPanel"
                ]
            },
            "start-server": {
                "methods": [
                    "startServer"
                ]
            },
            "stop-server": {
                "methods": [
                    "stopServer"
                ]
            },
            "get-server-status": {
                "methods": [
                    "getServerStatus"
                ]
            },
            "update-settings": {
                "methods": [
                    "updateSettings"
                ]
            },
            "getToolsList": {
                "methods": [
                    "getToolsList"
                ]
            },
            "get-server-settings": {
                "methods": [
                    "getServerSettings"
                ]
            },
            "getToolManagerState": {
                "methods": [
                    "getToolManagerState"
                ]
            },
            "createToolConfiguration": {
                "methods": [
                    "createToolConfiguration"
                ]
            },
            "updateToolConfiguration": {
                "methods": [
                    "updateToolConfiguration"
                ]
            },
            "deleteToolConfiguration": {
                "methods": [
                    "deleteToolConfiguration"
                ]
            },
            "setCurrentToolConfiguration": {
                "methods": [
                    "setCurrentToolConfiguration"
                ]
            },
            "updateToolStatus": {
                "methods": [
                    "updateToolStatus"
                ]
            },
            "updateToolStatusBatch": {
                "methods": [
                    "updateToolStatusBatch"
                ]
            },
            "exportToolConfiguration": {
                "methods": [
                    "exportToolConfiguration"
                ]
            },
            "importToolConfiguration": {
                "methods": [
                    "importToolConfiguration"
                ]
            },
            "getEnabledTools": {
                "methods": [
                    "getEnabledTools"
                ]
            }
        },
        "scene": {
            "script": "./dist/scene.js",
            "methods": [
                "addComponentToNode",
                "addEventHandler",
                "applyPrefab",
                "changePreviewPlayState",
                "checkAnimationFinished",
                "createNode",
                "createPrefabFromNode",
                "findNodeByName",
                "getAllNodes",
                "getAnimationClips",
                "getAnimationStateInfo",
                "getCurrentSceneInfo",
                "getNodeInfo",
                "getPrefabData",
                "getSceneHierarchy",
                "linkPrefab",
                "listAnimationStates",
                "listEventHandlers",
                "playAnimation",
                "queryAnimationSetTargets",
                "removeEventHandler",
                "runWithCapture",
                "setAnimationSpeed",
                "setNodeProperty",
                "stopAnimation",
                "unlinkPrefab"
            ]
        }
    }
}
