# ---- Dependencies ----
node_modules/

# ---- TypeScript build cache ----
*.tsbuildinfo

# Note: `dist/` is intentionally TRACKED in this repo because it ships as a
# Cocos Creator editor extension; end users install the extension without
# running `npm run build`. See CLAUDE.md for the convention.

# ---- Logs ----
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---- Cache / coverage / test output ----
.npm/
.eslintcache
.cache/
.parcel-cache/
coverage/
.nyc_output/
*.lcov

# ---- Env files (never commit secrets) ----
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# ---- Editors — per-user, not shared ----
.idea/
*.iml
*.swp
*.swo
*~

# VS Code: ignore everything except shared workspace configs.
# Allow listing extensions, debug launch configs, and tasks to be checked in;
# personal settings.json stays local.
.vscode/*
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# ---- OS noise ----
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db
desktop.ini
$RECYCLE.BIN/

# ---- Temp ----
*.tmp
*.temp
tmp/
temp/

# ---- CodeGraph (personal per-machine tooling, not project infra) ----
# CodeGraph is a per-developer code-intelligence tool, opted into via the
# user's global ~/.claude/CLAUDE.md — this project does not depend on it.
# Keep the whole setup local, not in the shared repo:
#   .codegraph/     index db / WAL / socket / pid / log (rebuilt locally)
#   .mcp.json       wires up the codegraph MCP server
#   .claude/CLAUDE.md, .claude/settings.json  codegraph usage hint + permission
# If a genuine PROJECT-level MCP server or .claude config is added later,
# force-track that specific file rather than un-ignoring this personal setup.
.codegraph/
.mcp.json
.claude/CLAUDE.md
.claude/settings.json

# ---- Claude Code session runtime ----
# Lock file written by ScheduleWakeup / dynamic loop runtime; per-session, no
# value to share. Project-level rules (if added later) live under
# .claude/rules/ and remain trackable.
.claude/scheduled_tasks.lock
# Per-machine settings overlay; should never be committed.
.claude/settings.local.json
